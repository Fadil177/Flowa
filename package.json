{
  "name": "flowa",
  "version": "0.1.0",
  "private": true,
  "description": "Flowa MVP monorepo with a static frontend and Node.js backend.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node backend/src/server.mjs",
    "start:backend": "node backend/src/server.mjs",
    "start:frontend": "node frontend/server.mjs",
    "test": "node backend/test/smoke.test.mjs"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=20"
  }
}
